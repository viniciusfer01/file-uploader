generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FileRecord {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())

  @@map("files")
}

